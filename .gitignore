# Local .terraform directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (which often contain secrets)
*.tfvars
*.tfvars.json

# Ignore Private Keys (สำคัญมาก!)
*.pem
terrakey
terrakey.pub

# Ignore temporary files
.terraform.lock.hcl